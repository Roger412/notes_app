{
  "expo": {
    "name": "NotesApp",
    "slug": "notes-app",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/baeb36b8-5a76-4250-b7c8-d73d2245e2ca"
    },
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "notesapp",
    "android": {
      "package": "com.notesapp.mobile",
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#181825"
      }
    },
    "ios": {
      "bundleIdentifier": "com.notesapp.mobile",
      "icon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "Allow $(PRODUCT_NAME) to use your microphone for voice commands in the controller."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "baeb36b8-5a76-4250-b7c8-d73d2245e2ca"
      }
    }
  }
}
